{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.tabstack.io/b2b-intel/api-documentation-endpoint.json",
  "title": "API Documentation Endpoint",
  "description": "Schema for individual API endpoint entries extracted from API documentation pages.",
  "type": "object",
  "$defs": {
    "parameter": {
      "type": "object",
      "description": "An API request parameter.",
      "properties": {
        "name": { "type": "string", "description": "Parameter name." },
        "location": { "type": "string", "description": "Where the parameter is passed (query, path, header, body)." },
        "type": { "type": "string", "description": "Data type of the parameter." },
        "required": { "type": "boolean", "description": "Whether this parameter is required." },
        "description": { "type": "string", "description": "Description of the parameter." },
        "example": { "description": "Example value for the parameter." }
      },
      "required": ["name"]
    },
    "response_code": {
      "type": "object",
      "description": "An HTTP response code and its description.",
      "properties": {
        "code": { "type": "number", "description": "HTTP status code." },
        "description": { "type": "string", "description": "Description of this response code." }
      },
      "required": ["code"]
    }
  },
  "properties": {
    "company_name": {
      "type": "string",
      "description": "Name of the company providing the API.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["docs page header", "API brand name", "site logo"]
    },
    "company_domain": {
      "type": "string",
      "description": "Website domain of the API provider.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["site URL", "docs URL domain", "canonical URL"]
    },
    "api_name": {
      "type": "string",
      "description": "Name of the API product.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["API docs header", "API product name", "breadcrumb"]
    },
    "api_version": {
      "type": "string",
      "description": "Version of the API (e.g., v1, 2024-01-01).",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["API version badge", "docs navigation", "URL path"]
    },
    "endpoint_path": {
      "type": "string",
      "description": "URL path of the API endpoint (e.g., /v1/users/{id}).",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["endpoint path display", "API reference heading", "code snippet URL"]
    },
    "http_method": {
      "type": "string",
      "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"],
      "description": "HTTP method for the endpoint.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["HTTP method badge", "endpoint label", "code example"]
    },
    "title": {
      "type": "string",
      "description": "Short title or name for the endpoint.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["endpoint section heading", "API reference title", "sidebar navigation item"]
    },
    "description": {
      "type": "string",
      "description": "Description of what the endpoint does.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["endpoint description text", "API reference body", "docs paragraph"]
    },
    "auth_type": {
      "type": "string",
      "enum": ["api_key", "oauth2", "bearer", "basic", "none"],
      "description": "Authentication type required for this endpoint.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["authentication section", "auth badge", "security requirements"]
    },
    "parameters": {
      "type": "array",
      "items": { "$ref": "#/$defs/parameter" },
      "description": "List of request parameters for this endpoint.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["parameters table", "request parameters section", "query params list"]
    },
    "request_body_schema": {
      "type": "object",
      "description": "JSON Schema or description of the request body.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["request body section", "body schema table", "example request"]
    },
    "response_codes": {
      "type": "array",
      "items": { "$ref": "#/$defs/response_code" },
      "description": "HTTP response codes returned by this endpoint.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["response codes table", "returns section", "status codes list"]
    },
    "rate_limit_requests": {
      "type": "number",
      "description": "Number of requests allowed in the rate limit window.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["rate limits section", "throttling details", "API limits table"]
    },
    "rate_limit_window": {
      "type": "string",
      "description": "Time window for the rate limit (e.g., '1 minute', '1 hour').",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["rate limits section", "throttling details", "API limits table"]
    },
    "is_deprecated": {
      "type": "boolean",
      "description": "Whether this endpoint is deprecated.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["deprecated badge", "deprecation notice", "endpoint warning banner"]
    },
    "deprecation_date": {
      "type": "string",
      "format": "date",
      "description": "Date this endpoint was or will be deprecated.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["deprecation notice date", "sunset date field", "migration guide"]
    },
    "docs_url": {
      "type": "string",
      "format": "uri",
      "description": "URL of the documentation page for this endpoint.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["canonical link", "docs navigation link", "source page URL"]
    },
    "source_url": {
      "type": "string",
      "format": "uri",
      "description": "URL of the page from which this data was extracted.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["browser URL bar", "canonical link tag", "og:url meta tag"]
    },
    "extracted_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when this data was extracted.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["extraction metadata", "scraper system timestamp"]
    }
  },
  "required": ["company_name", "endpoint_path", "http_method", "source_url", "extracted_at"]
}

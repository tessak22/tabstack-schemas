{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.tabstack.io/b2b-intel/product-changelog-entry.json",
  "title": "Product Changelog Entry",
  "description": "Schema for individual product changelog or release note entries.",
  "type": "object",
  "properties": {
    "company_name": {
      "type": "string",
      "description": "Name of the company publishing the changelog.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["site header", "changelog page header", "og:site_name meta tag"]
    },
    "company_domain": {
      "type": "string",
      "description": "Website domain of the company.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["site URL", "canonical domain", "changelog URL"]
    },
    "product_name": {
      "type": "string",
      "description": "Name of the specific product or component.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["changelog entry header", "product tag", "release notes section title"]
    },
    "version": {
      "type": "string",
      "description": "Version number or release identifier.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["changelog version heading", "release tag", "version badge"]
    },
    "release_date": {
      "type": "string",
      "format": "date",
      "description": "Date of this changelog entry or release.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["changelog entry date", "release date display", "article publish date"]
    },
    "change_type": {
      "type": "string",
      "enum": ["feature", "improvement", "bugfix", "deprecation", "security", "breaking_change"],
      "description": "Type of change described in this entry.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["change type badge", "changelog category label", "entry tag"]
    },
    "title": {
      "type": "string",
      "description": "Title or headline of the changelog entry.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["changelog entry heading", "release note title", "h2/h3 tag"]
    },
    "description": {
      "type": "string",
      "description": "Full description of the change.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["changelog entry body", "release note description", "change detail text"]
    },
    "affected_products": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Products or modules affected by this change.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["product tag labels", "affected products list", "changelog entry metadata"]
    },
    "affected_plans": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Pricing plans affected by this change.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["plan availability note", "plan tag labels", "changelog metadata"]
    },
    "is_breaking": {
      "type": "boolean",
      "description": "Whether this is a breaking change.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["breaking change badge", "breaking label", "changelog entry flag"]
    },
    "migration_required": {
      "type": "boolean",
      "description": "Whether migration steps are required for this change.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["migration notice", "action required label", "breaking change section"]
    },
    "migration_guide_url": {
      "type": "string",
      "format": "uri",
      "description": "URL to the migration guide for this change.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["migration guide link", "learn more link", "documentation link in changelog"]
    },
    "changelog_url": {
      "type": "string",
      "format": "uri",
      "description": "URL of the changelog page.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["canonical link", "changelog navigation link", "source page URL"]
    },
    "source_url": {
      "type": "string",
      "format": "uri",
      "description": "URL of the page from which this entry was extracted.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["browser URL bar", "canonical link tag", "og:url meta tag"]
    },
    "extracted_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when this entry was extracted.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["extraction metadata", "scraper system timestamp"]
    }
  },
  "required": ["company_name", "release_date", "change_type", "title", "description", "source_url", "extracted_at"]
}
